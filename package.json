{
  "name": "buzz-bot-frontend",
  "private": true,
  "scripts": {
    "build": "esbuild src/js/entry.js --bundle --minify --loader:.js=jsx --jsx=automatic --jsx-import-source=preact --outfile=public/js/miniplayer.js",
    "watch": "esbuild src/js/entry.js --bundle --loader:.js=jsx --jsx=automatic --jsx-import-source=preact --outfile=public/js/miniplayer.js --watch"
  },
  "devDependencies": {
    "@preact/signals": "^1.3.0",
    "esbuild": "^0.21.5",
    "preact": "^10.22.0"
  }
}
