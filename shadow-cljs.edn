{:source-paths ["src/cljs"]
 :dependencies [[reagent "1.2.0"]
                [re-frame "1.4.3"]]
 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn buzz-bot.core/init!}}
        :release    {:compiler-options {:source-map "public/js/main.js.map"}}
        :devtools   {:repl-init-ns buzz-bot.core}}}}
