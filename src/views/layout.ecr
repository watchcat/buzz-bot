<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buzz-Bot</title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <link rel="stylesheet" href="/css/app.css?v=<%= Assets::VERSION %>">
</head>
<body>
  <div id="app">
    <div class="app-container">
      <nav class="tab-bar">
        <button class="tab-btn active"
                hx-get="/inbox"
                hx-target="#content"
                hx-trigger="click"
                hx-include="[name='initData']"
                onclick="setActiveTab(this)">
          📥 Inbox
        </button>
        <button class="tab-btn"
                hx-get="/feeds"
                hx-target="#content"
                hx-trigger="click"
                hx-include="[name='initData']"
                onclick="setActiveTab(this)">
          📻 Feeds
        </button>
        <button class="tab-btn"
                hx-get="/discover"
                hx-target="#content"
                hx-trigger="click"
                hx-include="[name='initData']"
                onclick="setActiveTab(this)">
          🔍 Discover
        </button>
      </nav>

      <main id="content"
            hx-get="/inbox"
            hx-trigger="load"
            hx-include="[name='initData']">
        <div class="loading">Loading...</div>
      </main>
    </div>

    <input type="hidden" name="initData" id="initData" value="">
  </div>

  <!-- Persistent audio element — lives outside #content so HTMX swaps never destroy it -->
  <div id="now-playing" class="now-playing-bar" hidden>
    <audio id="episode-audio" preload="metadata"></audio>
    <div class="now-playing-inner" id="now-playing-tap">
      <div class="now-playing-artwork" id="now-playing-artwork"></div>
      <div class="now-playing-text">
        <span class="now-playing-title" id="now-playing-title"></span>
        <span class="now-playing-podcast" id="now-playing-podcast"></span>
      </div>
    </div>
    <button class="btn-speed" id="now-playing-speed-btn" onclick="cycleSpeed()">1×</button>
    <button class="now-playing-playpause" id="now-playing-playpause" onclick="togglePlayPause()">▶</button>
  </div>

  <script>window.BOT_USERNAME = '<%= BotClient.username %>';</script>
  <script src="/js/app.js?v=<%= Assets::VERSION %>"></script>
</body>
</html>
